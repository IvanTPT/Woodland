---
const { data } = Astro.props;
---
<section class="section">
  <div class="section__inner w-full max-w-6xl mx-auto px-4">
    <h2 class="section__title">План и програм</h2>
    
    <div class="plan-grid">
      <!-- ЛЕВА СТРАНА: План -->
      <div class="schedule-list">
        <!-- Додајемо индекс у map функцију како бисмо направили кашњење -->
        {data.lokacije.map((stavka: any, index: number) => (
          <!-- Динамички убацујемо transition-delay да сваки следећи елемент касни 100ms -->
          <div class="schedule-item" style={`transition-delay: ${index * 100}ms;`}>
            <div class="schedule-header">
              <span class="time">{stavka.vreme}</span>
              <span class="separator">—</span>
              <h3>{stavka.naziv}</h3>
            </div>
            
            <div class="details">
              <p>{stavka.opis}</p>
            </div>
          </div>
        ))}
      </div>
      
      <!-- ДЕСНА СТРАНА: Мапа -->
      <div class="map-container">
        <iframe 
          src={data.mapa_embed} 
          allowfullscreen="" 
          loading="lazy">
        </iframe>
      </div>
    </div>

  </div>
</section>

<style>
  /* === ГЛАВНИ GRID ЗА РАСПОРЕД === */
  .plan-grid {
    display: grid;
    grid-template-columns: 1fr; 
    gap: 2rem;
    align-items: stretch;
    margin-top: 2.5rem;
  }

  @media (min-width: 768px) {
    .plan-grid {
      grid-template-columns: 1fr 1fr; 
      gap: 3rem;
    }
  }

  /* === СТИЛОВИ ЗА ЛЕВУ СТРАНУ (ПЛАН) === */
  .schedule-list {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
  }

  .schedule-item {
    background: rgba(255, 255, 255, 0.85);
    padding: 1.5rem;
    border-radius: 1rem;
    border-left: 4px solid var(--color-accent);
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    
    /* Почетно стање за анимацију */
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  /* Стање када постане видљиво */
  .schedule-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Ховер ефекат - исправљен да не поништава видљивост */
  .schedule-item.is-visible:hover {
    transform: translateY(0) translateX(10px);
  }

  .schedule-header {
    display: flex;
    align-items: baseline; 
    gap: 0.75rem; 
    margin-bottom: 0.5rem;
    flex-wrap: wrap; 
  }

  .time {
    font-weight: bold;
    color: var(--color-accent);
    font-size: 1.5rem;
  }

  .separator {
    color: var(--color-accent);
    font-weight: bold;
    opacity: 0.7;
  }

  .schedule-header h3 {
    font-size: 1.25rem;
    font-weight: bold;
    color: var(--color-primary);
    margin: 0; 
  }

  .details p {
    color: var(--color-text-dark);
    opacity: 0.8;
    line-height: 1.6;
    margin: 0;
  }

  /* === СТИЛОВИ ЗА ДЕСНУ СТРАНУ (МАПА) === */
  .map-container {
    /* Враћени обрисани стилови како мапа не би пукла */
    background: rgba(255, 255, 255, 0.85);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(181, 141, 104, 0.3);
    min-height: 350px; 
    position: relative; 
    width: 100%;
    
    /* Анимација */
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .map-container.is-visible {
    opacity: 1;
    transform: scale(1);
  }
  
  .map-container iframe {
    position: absolute; 
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>

<script>
  // Покрећемо скрипту када се DOM учита да осигурамо да су елементи ту
  document.addEventListener('DOMContentLoaded', () => {
    const scheduleItems = document.querySelectorAll('.schedule-item');
    const mapContainer = document.querySelector('.map-container');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Једноставно додајемо класу, кашњење сада ради преко CSS transition-delay-a
          entry.target.classList.add('is-visible');
          
          // Опционо: престајемо да посматрамо елемент како се не би поново анимирао кад скролујеш горе
          observer.unobserve(entry.target); 
        }
      });
    }, { threshold: 0.1 });

    scheduleItems.forEach(item => observer.observe(item));
    if (mapContainer) observer.observe(mapContainer);
  });
</script>
