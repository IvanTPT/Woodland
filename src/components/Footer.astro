---
const { data, imena } = Astro.props;
---
<footer class="site-footer">
  <div id="footer-inner" class="footer-content">
    
    <!-- Главна порука са сјајним ефектом -->
    <h2 class="footer-title">
      С љубављу за младенце<br/>
      <span class="highlight-text text-3xl md:text-5xl mt-2 block">за наше венчање 💍</span><br/>
      {imena}
    </h2>
    
    <div class="divider"></div>
    
    <!-- Израђено у Србији -->
    <p class="made-in">
      Са поносом израђено у Србији <span class="beating-heart">❤️</span>
    </p>
    
    <!-- Контакт секција -->
    <div class="contact-box" id="interactive-contact">
      <p class="contact-label">За сва ваша весеља:</p>

      <!-- Потпис аутора -->
      <p class="author-signature"><a href="https://radujse.online/"</a>{data.kreator}</p>
      
      <!-- Интерактивни Email -->
      <a href={`mailto:${data.kontakt}`} class="email-link">
        <span class="email-text">{data.kontakt}</span>
      </a>
      

    </div>

  </div>
</footer>

<script>
  // 1. Анимација појављивања при скроловању
  const footerInner = document.getElementById('footer-inner');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, { threshold: 0.1 });

  if (footerInner) observer.observe(footerInner);

  // 2. Интерактивност: Летећа срца на ховер преко контакт секције
  const contactBox = document.getElementById('interactive-contact');
  let lastHeartTime = 0;

  contactBox?.addEventListener('mousemove', (e) => {
    const now = Date.now();
    // Ограничавамо креирање срца на сваких 100ms
    if (now - lastHeartTime > 100) {
      createHeart(e.clientX, e.clientY);
      lastHeartTime = now;
    }
  });

  function createHeart(x: number, y: number) {
    const heart = document.createElement('div');
    heart.innerHTML = '🤍';
    heart.className = 'floating-particle';
    
    const offsetX = (Math.random() - 0.5) * 40;
    const offsetY = (Math.random() - 0.5) * 40;
    
    heart.style.left = `${x + offsetX}px`;
    heart.style.top = `${y + offsetY}px`;
    
    document.body.appendChild(heart);

    setTimeout(() => {
      heart.remove();
    }, 1500);
  }
</script>

<style>
  /* === ОСНОВНИ ФУТЕР === */
  .site-footer {
    background-color: var(--color-primary);
    color: var(--color-secondary);
    padding: 8rem 2rem 4rem 2rem;
    position: relative;
    overflow: hidden;
    text-align: center;
    border-top: 4px solid var(--color-accent);
  }

  /* === АНИМАЦИЈА ПРИ УЧИТАВАЊУ === */
  .footer-content {
    max-width: 800px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(60px) scale(0.95);
    transition: opacity 1.2s cubic-bezier(0.2, 0.8, 0.2, 1), 
                transform 1.2s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .footer-content.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* === ТИПОГРАФИЈА И СЈАЈНИ ЕФЕКТИ === */
  .footer-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.2;
    margin-bottom: 2rem;
    color: #ffffff; /* Чисто бела боја за максималан контраст */
    text-shadow: 0 0 15px rgba(255, 255, 255, 0.4), 0 4px 10px rgba(0, 0, 0, 0.5); /* Сјај + тамна сенка испод */
  }

  .highlight-text {
    color: #f4f1ea; /* Блага крем боја */
    text-shadow: 0 0 20px rgba(181, 141, 104, 0.8), 0 2px 5px rgba(0,0,0,0.6); /* Златни сјај */
  }

  .divider {
    width: 80px;
    height: 2px;
    background: var(--color-accent);
    margin: 2rem auto;
    box-shadow: 0 0 10px var(--color-accent);
  }

  .made-in {
    font-size: 1.2rem;
    color: #ffffff;
    opacity: 0.9;
    margin-bottom: 4rem;
    letter-spacing: 0.05em;
  }

  /* Анимација куцања срца */
  .beating-heart {
    display: inline-block;
    animation: heartbeat 1.5s infinite;
  }

  @keyframes heartbeat {
    0% { transform: scale(1); }
    15% { transform: scale(1.3); }
    30% { transform: scale(1); }
    45% { transform: scale(1.3); }
    60%, 100% { transform: scale(1); }
  }

  /* === КОНТАКТ СЕКЦИЈА === */
  .contact-box {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 3rem 2rem;
    border-radius: 1.5rem;
    backdrop-filter: blur(10px);
    cursor: pointer;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .contact-box:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.08);
  }

  .contact-label {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  /* Сјајни Емаил Линк */
  .email-link {
    display: inline-block;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: bold;
    font-family: var(--font-lato);
    color: white;
    text-decoration: none;
    position: relative;
    padding: 0.5rem;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .email-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    transform: skewX(-20deg);
    transition: 0s;
  }

  .email-link:hover::before {
    left: 200%;
    transition: 0.8s ease-in-out;
  }

  .email-text {
    position: relative;
    z-index: 2;
    transition: text-shadow 0.3s ease;
  }

  .email-link:hover .email-text {
    text-shadow: 0 0 15px rgba(255, 255, 255, 0.8);
  }

  /* === ПОТПИС АУТОРА === */
  .author-signature {
    font-family: var(--font-display); /* Користи Marck Script */
    font-size: 1.6rem; /* Мањи формат у односу на наслове */
    letter-spacing: 0.15em; /* Раширено */
    color: var(--color-secondary);
    opacity: 0.8;
    margin-top: 0.5rem;
    text-shadow: 1px 1px 3px rgba(0,0,0,0.3); /* Блага сенка да се издвоји */
  }

  /* === СТИЛОВИ ЗА ЛЕТЕЋЕ ЧЕСТИЦЕ === */
  :global(.floating-particle) {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    font-size: 1.2rem;
    animation: floatUp 1.5s ease-out forwards;
    opacity: 0.8;
  }

  @keyframes floatUp {
    0% {
      transform: translateY(0) scale(0.5);
      opacity: 0.8;
    }
    100% {
      transform: translateY(-100px) scale(1.5) rotate(20deg);
      opacity: 0;
    }
  }
</style>
