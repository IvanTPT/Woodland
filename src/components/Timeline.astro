---
const { data } = Astro.props;
---
<section class="section">
  <div class="section__inner w-full max-w-6xl mx-auto px-4">
    <h2 class="section__title">Наша прича</h2>
    
    <div class="timeline-wrapper">
      <!-- Централна линија која пролази кроз целу секцију -->
      <div class="timeline-center-line"></div>
      
      {data.map((item: any, index: number) => {
        // Проверавамо да ли је парни или непарни елемент да бисмо знали на коју страну да га ставимо
        const isLeft = index % 2 === 0;
        
        return (
          <div class={`timeline-row ${isLeft ? 'left-row' : 'right-row'}`}>
            <!-- Декоративна тачка на самој линији -->
            <div class="timeline-dot"></div>
            
            <div class="timeline-content">
              <!-- Текстуални део (Наслов и опис) -->
              <div class="text-box">
                <h3>{item.naslov}</h3>
                <p>{item.tekst}</p>
              </div>
              
              <!-- Медијски део (Година и слика) -->
              <div class="media-box">
                <div class="year">{item.godina}</div>
                <img src={item.slika} alt={item.naslov} loading="lazy" />
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
<style>
  /* === GLAVNI OMOTAČ I LINIJA === */
  .timeline-wrapper {
    position: relative;
    max-width: 1100px; /* Povećano da bi bilo više mesta za tekst */
    margin: 0 auto;
    padding: 2rem 0;
  }

  .timeline-center-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--color-accent);
    opacity: 0.3;
    transform: translateX(-50%);
    z-index: 1;
  }

  /* === REDOVI === */
  .timeline-row {
    display: flex;
    width: 100%;
    margin-bottom: 6rem;
    position: relative;
  }

  .timeline-row:last-child {
    margin-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: 50%;
    top: 3.5rem; /* Poravnato sa sredinom velike godine */
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-background);
    border: 4px solid var(--color-accent);
    transform: translateX(-50%);
    z-index: 2;
    box-shadow: 0 0 10px rgba(0,0,0,0.05);
  }

  /* === SADRŽAJ I NAIZMENIČNI (CIK-CAK) RASPORED === */
  .timeline-content {
    display: flex;
    width: 50%; /* Zakucano na tačno 50% ekrana da nikad ne pređe liniju */
    gap: 2.5rem;
    align-items: center; 
  }

  /* LEVA STRANA */
  .left-row {
    justify-content: flex-start; 
  }
  .left-row .timeline-content {
    flex-direction: row; 
    padding-right: 4rem; /* Fiksni prostor od slike do centralne linije */
  }
  .left-row .text-box {
    text-align: right; 
  }
  .left-row .media-box {
    align-items: flex-end; 
  }

  /* DESNA STRANA */
  .right-row {
    justify-content: flex-end; 
  }
  .right-row .timeline-content {
    flex-direction: row-reverse; 
    padding-left: 4rem; /* Fiksni prostor od slike do centralne linije */
  }
  .right-row .text-box {
    text-align: left; 
  }
  .right-row .media-box {
    align-items: flex-start; 
  }

  /* === DIZAJN POJEDINAČNIH ELEMENATA === */
  .text-box {
    flex: 1; 
    min-width: 180px; /* Sprečava da se tekst slomi na po jedno slovo */
  }

  .text-box h3 {
    font-size: 2.25rem;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    font-family: var(--font-playfair); 
    line-height: 1.2;
  }

  .text-box p {
    font-size: 1.15rem;
    color: var(--color-text-dark);
    opacity: 0.8;
    line-height: 1.7;
  }

  .media-box {
    display: flex;
    flex-direction: column;
    width: 280px; /* Malo suženo kako bi tekst dobio na širini */
    flex-shrink: 0;
    position: relative;
    z-index: 3;
  }

  .year {
    font-family: var(--font-display); 
    font-size: 6.5rem;
    color: var(--color-accent);
    line-height: 0.8;
    margin-bottom: 0.5rem;
    text-shadow: 2px 2px 5px rgba(0,0,0,0.05);
  }

  .media-box img {
    width: 100%;
    height: 380px;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    border: 6px solid white; 
    transition: transform 0.4s ease;
  }

  .media-box:hover img {
    transform: translateY(-5px);
  }

  /* === PRILAGOĐAVANJE ZA MOBILNE TELEFONE === */
  @media (max-width: 900px) {
    .timeline-center-line {
      left: 20px;
      transform: none;
    }
    
    .timeline-dot {
      left: 20px;
      transform: translateX(-50%); 
    }

    .timeline-row {
      justify-content: flex-end; 
      margin-bottom: 5rem;
    }

    .timeline-content {
      width: 100%; 
      padding-left: 4rem !important; /* Gura sav sadržaj desno od linije na telefonu */
      padding-right: 1rem !important;
      flex-direction: column-reverse !important; 
      gap: 1.5rem;
      align-items: flex-start !important;
    }

    .left-row .text-box, .right-row .text-box {
      text-align: left;
    }
    
    .left-row .media-box, .right-row .media-box {
      width: 100%;
      max-width: 320px;
      align-items: flex-start;
    }

    .media-box img {
      height: 300px; 
    }

    .year {
      font-size: 4.5rem;
    }
  }
/* === АНИМАЦИЈЕ === */
  /* Почетно стање: провидна и помакнута у страну зависно од тога где се налази */
  .left-row .timeline-content {
    opacity: 0;
    transform: translateX(-50px);
    transition: opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .right-row .timeline-content {
    opacity: 0;
    transform: translateX(50px);
    transition: opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* Финално стање: видљиво и на свом месту */
  .timeline-row.is-visible .timeline-content {
    opacity: 1;
    transform: translateX(0);
  }

  /* Анимација тачке на линији (Попуп ефекат) */
  .timeline-dot {
    /* ... твоји постојећи стилови за dot ... */
    transform: translateX(-50%) scale(0);
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s; /* Касни мало са појављивањем */
  }

  .timeline-row.is-visible .timeline-dot {
    transform: translateX(-50%) scale(1);
  }
</style>
<script>
  const timelineRows = document.querySelectorAll('.timeline-row');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, { threshold: 0.2 }); // Активира се када се види бар 20% блока

  timelineRows.forEach(row => observer.observe(row));
</script>
