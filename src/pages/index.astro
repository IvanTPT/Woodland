---
import Layout from '../layouts/Layout.astro';
import config from '../data/config.yml';

import Hero from '../components/Hero.astro';
import Timeline from '../components/Timeline.astro';
import Plan from '../components/Plan.astro';
import RsvpAndPhotos from '../components/RsvpAndPhotos.astro';
import Quote from '../components/Quote.astro';
import HeartDivider from '../components/HeartDivider.astro';
import Footer from '../components/Footer.astro';
---

<Layout title={config.vencanje.imena}>
  <Hero data={config.vencanje} />
  <HeartDivider/>
  <Timeline data={config.prica} />
  <HeartDivider/>
  <Plan data={config.plan} />
  <HeartDivider/>
  <RsvpAndPhotos data={config.interakcija} datumVencanja={config.vencanje.datum_iso} />
  <HeartDivider/>
  <Quote data={config.citat} />
  <Footer data={config.footer} imena={config.vencanje.imena} />
</Layout>