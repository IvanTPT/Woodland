---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="sr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Позивница за венчање и прославу." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph Image за дељење на мрежама -->
    <meta property="og:image" content={new URL("/og.png", Astro.site)} />
    <meta property="og:image:width" content="900" />
    <meta property="og:image:height" content="1175" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Главни садржај свих компоненти се учитава овде -->
    <main>
      <slot />
    </main>

    <!-- Скрипта за аутоматско покретање анимација приликом скроловања -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        // Подешавамо када секција треба да постане видљива
        const observerOptions = {
          root: null,
          rootMargin: "0px",
          threshold: 0.15 // Активира се када се види 15% секције
        };

        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Када секција уђе у екран, додајемо класу која окида CSS транзицију
              entry.target.classList.add('is-visible');
              
              // Престајемо да је пратимо како се не би стално анимирала горе-доле
              observer.unobserve(entry.target); 
            }
          });
        }, observerOptions);

        // Проналазимо све елементе са класом 'section' и започињемо праћење
        const sections = document.querySelectorAll('.section');
        sections.forEach(section => {
          observer.observe(section);
        });
      });
    </script>
  </body>
</html>
